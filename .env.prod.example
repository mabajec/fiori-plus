# Production environment for docker-compose.prod.yml.
# Copy to .env.prod and fill in the secrets. NEVER commit the real file.

# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=fiori
POSTGRES_DB=fiori
# Pick a long random password. Suggestion:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# ─── App ─────────────────────────────────────────────────────────────────────
# Signs the session cookie. Anyone with this can forge logins, treat it like
# a password. Suggestion:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=change-me-to-a-long-random-string

# Flip to true once Traefik puts HTTPS in front; the cookie will then be
# marked Secure and only sent over TLS. Keep false while serving plain HTTP.
SESSION_HTTPS_ONLY=false

# Port the app listens on (host side). The reverse proxy targets this.
APP_PORT=8000

# Optional: identity of the auto-created admin (used by `fiori init`).
DEFAULT_ADMIN_EMAIL=admin@local
DEFAULT_ADMIN_NAME=Admin

# ─── Filesystem ──────────────────────────────────────────────────────────────
# Where on the host TSV exports live. Defaults to ./inputs (relative to the
# compose file). Uncomment + override if you want exports to live somewhere
# else on the host — e.g. on a separate data volume.
# HOST_INPUTS_DIR=/srv/fiori/inputs
